FLASK_ENV=development
SECRET_KEY=troque-esta-chave-em-producao

# Banco
DATABASE_URL=sqlite:///instance/db.sqlite

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage (MinIO local ou S3)
STORAGE_BACKEND=local        # local | s3
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=editais

# ---------------------------------------------------------------
# LLM (usa LiteLLM — troque modelo + chave para mudar provedor)
#
# Anthropic (Claude):  LLM_MODEL=claude-haiku-4-5-20251001  + ANTHROPIC_API_KEY
# OpenAI (GPT):        LLM_MODEL=gpt-4o-mini               + OPENAI_API_KEY
# Google (Gemini):     LLM_MODEL=gemini/gemini-1.5-flash    + GEMINI_API_KEY
# ---------------------------------------------------------------
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
